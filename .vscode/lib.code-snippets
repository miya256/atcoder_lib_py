      "",
      "    def transpose(self) -> \"Matrix\":",
      "        \"\"\"転置行列\"\"\"",
      "        data = [self[i,j] for j in range(self.m) for i in range(self.n)]",
      "        return Matrix._from_vector(data, self.m, self.n)",
