      "            is_dag        : グラフがDAGか",
      "            is_unique     : トポロジカル順が一意に定まるか",
      "        \"\"\"",
      "",
      "    def __init__(self, n: int, m: int) -> None:",
      "        super().__init__(n, m)",
      "        self._is_dag: bool | None = None",
      "        self._is_unique: bool | None = None",
      "    ",
      "    def sort(self, key=None) -> list[int] | None:",
      "        \"\"\"トポロジカルソート\"\"\"",
      "        self._is_dag = None",
      "        self._is_unique = None",
      "        if key is None:",
      "            return self._sort_by_dfs()",
